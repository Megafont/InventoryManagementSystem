@page "/productreport"

@rendermode InteractiveServer

@inject IJSRuntime JSRuntime

@inject ISearchProductTransactionsUseCase SearchProductTransactionsUseCase

<!--We added a printarea block in app.css to force it to ignore the side bar and top bar when printing.-->
<div id="printarea">
    <h3>Product Transactions</h3>
    <br />

    <div class="row">
        <div class="col">
            <label for="productName">Inventory Name</label>
            <input type="text" id="productName" class="form-control" @bind-value="_productName" />
        </div>
        <div class="col">
            <label for="dateFrom">Date From</label>
            <input type="date" id="dateFrom" class="form-control" @bind-value="_dateFrom"/>
        </div>
        <div class="col">
            <label for="dateTo">Date To</label>
            <input type="date" id="dateTo" class="form-control" @bind-value="_dateTo" />
        </div>
        <div class="col">
            <label for="activityType">Transaction Type</label>
            <select id="activityType" class="form-control" @bind="_transactionTypeID">
                <option value="0"></option>
                <option value="1">Produce Product</option>
                <option value="2">Sell Product</option>
            </select>
        </div>
        <div class="col">
            <label>&nbsp;</label>
            <button type="button" class="btn btn-primary form-control" @onclick="SearchInventoryTransactions">Search</button>
        </div>
        <div class="col">
            <label>&nbsp;</label>
            <button type="button" class="btn btn-primary form-control" @onclick="Print">Print</button>
        </div>
    </div>

    <!--This originally used _inventoryTransactions.Count() > 0 for the second condition.
    However, Visual Studio suggested using the Any() method instead, since it is faster by not iterating the entire collection.
    It also makes our intent here clearer. We don't care how many items are in the collection, just that there is at least 1.
-->
    @if (_productTransactions != null && _productTransactions.Any())
    {
        <table class="table">
            <thead>
            <tr>
                <th>Date</th>
                <th>Product</th>
                <th>Transaction Type</th>
                <th>Quantity Before</th>
                <th>Quantity After</th>
                <th>Unit Price</th>
                <th>Sales Order #</th>
                <th>Production #</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var productTransaction in _productTransactions)
            {
                <tr>
                    <td>@productTransaction.TransactionDate.ToString("MM/dd/yyyy")</td>
                    <td>@productTransaction.Product.ProductName</td>
                    <td>
                        @if (productTransaction.ActivityType == ProductTransactionTypes.ProduceProduct)
                        {
                            <text>Produce</text>
                        }
                        else if (productTransaction.ActivityType == ProductTransactionTypes.SellProduct)
                        {
                            <text>Sell</text>
                        }
                    </td>
                    <td>@productTransaction.QuantityBefore</td>
                    <td>@productTransaction.QuantityAfter</td>
                    <td>@productTransaction.UnitPrice?.ToString("c")</td>
                    <td>@productTransaction.SalesOrderNumber</td>
                    <td>@productTransaction.ProductionNumber</td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>

@code 
{
    private string _productName;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private int? _transactionTypeID;

    private IEnumerable<ProductTransaction>? _productTransactions;


    private async Task SearchInventoryTransactions()
    {
        ProductTransactionTypes? transactionType = null;
        if (_transactionTypeID.HasValue && _transactionTypeID != 0) transactionType = (ProductTransactionTypes) _transactionTypeID;

        _productTransactions = await SearchProductTransactionsUseCase.ExecuteAsync
        (
            _productName, 
            _dateFrom, 
            _dateTo, 
            transactionType
        );
    }

    private async Task Print()
    {
        // Use Javascript interop to call the Window.Print() method to print this inventory transactions report page.
        // NOTE: We added a printarea block in app.css to force it to ignore the side bar and top bar when printing.
        await JSRuntime.InvokeVoidAsync("print");
    }
}
