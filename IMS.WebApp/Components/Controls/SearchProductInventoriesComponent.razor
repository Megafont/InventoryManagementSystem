
@inject IGetInventoriesByNameUseCase GetInventoriesByNameUseCase

<div class="input-group">
    <!--IMPORTANT:
            In this case the bind-value attribute needs to use a lower-case v, instead of an upper-case one like we used in AddInventory.razor.
            Also, the bind-value:event attribute tells it to fire the binding event on every input change, rather than only when the input loses focus.
            This is important, as we want the search results to update as the user types, rather than waiting for them to click the Search button.
    -->
    <input class="form-control"
           placeholder="Type something here to search"
           @bind-value="SearchFilter"
           @bind-value:event="oninput">

    <button type="button"
            class="btn-success input-group-text"
            @onclick="HandleSearch"
            style="color: white; background-color: darkgreen;">
        Search
    </button>
</div>

@if (_inventories is not null && _inventories.Count > 0)
{
    <!--This div is creating a drop-down list essentially. The style here is telling the div to add a vertical scrollbar. Then we set the max-height for this div.-->
    <div class="search-result">

        <!--The style attribute in this ul tag is telling it to not show bullet points.-->
        <ul>
            @foreach (var inventory in _inventories)
            {
                <!--IMPORTANT: 
                    We are setting the list item's key equal to the inventory ID of the inventory it represents. This allows Blazor to tell which list item is which
                    so it can update only the ones that have changed, rather than re-rendering the entire list every time the user searches. This is useful for performance
                    if there are a large number of inventories.
                    
                    We also set the cursor style to pointer here so that the user knows they can click on the inventory name to select it. This is a common UI pattern for clickable items.
                -->
                <li
                    @key="inventory.InventoryID"
                    @onclick="() => { HandleSelectInventory(inventory); }">

                        @inventory.InventoryName
                </li>
            }
        </ul>

    </div>
}


@code 
{
    [Parameter]
    public EventCallback<Inventory> OnInventorySelected { get; set; }

    private string _searchFilter = string.Empty;

    // The [SupplyParameterFromForm] attribute is intentionally missing here. It is only used with static SSR (server-side rendering).
    // It is not necessary when using the interactive SSR render mode, which we are using here.
    public string SearchFilter
    {
        get => _searchFilter;
        set
        {
            _searchFilter = value;
            // This line has a squiggly underline because HandleSearch() is an async function. However, you cannot use async/await in a getter/setter.
            // This still works, but it will just run it synchronously instead.
#pragma warning disable CS4014 // Because this call is not awaited, execution of the current method continues before the call is completed
            HandleSearch();
#pragma warning restore CS4014 // Because this call is not awaited, execution of the current method continues before the call is completed
        }
    }

    private List<Inventory> _inventories = new();


    private async Task HandleSearch()
    {
        //await Task.Delay(2000); // Simulate the delay that may occur in a complex real-world database search with lots of inventories.

        _inventories = (await GetInventoriesByNameUseCase.ExecuteAsync(_searchFilter)).ToList();

        // This method is built into Blazor components. It tells blazor that the component's state has changed and that it needs to re-render the UI.
        // Otherwise, if the inventories search takes too long, the UI will already have rendered when the data comes back. Thus, the UI will not be
        // correctly updated. This tells it to update it at that point.
        StateHasChanged();
    }

    private async Task HandleSelectInventory(Inventory inventory)
    {
        await OnInventorySelected.InvokeAsync(inventory);
        
        // We clear the inventories state variable here, which triggers that section of the UI to update. Since the list is now empty, that part of the UI disappears.
        _inventories.Clear();
    }
}
